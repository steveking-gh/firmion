region FLASH1 {
    addr = 0x08000000;
    size = 0x00100000;
}
region FLASH2 {
    addr = 0x09000000;
    size = 0x00100000;
}
region RAM {
    addr = 0x20000000;
    size = 0x00010000;
    default_pad_byte = 0xAA;
}

section sec_flash in FLASH1 {
    wr8 0x11;
    align 4;  // should pad with default_pad_byte of FLASH1 (0xFF)
}

section sec_ram in RAM {
    wr8 0x22;
    align 4;  // should pad with default_pad_byte of RAM (0xAA)
}

section sec_unbound {
    wr8 0x33;
    align 4;  // should pad with 0x00
}

section sec_override in FLASH2 {
    wr8 0x44;
    align 4, 0xEE;  // should pad with explicit 0xEE
}

section top {
    wr sec_flash;
    wr sec_ram;
    wr sec_unbound;
    wr sec_override;
}

output top;
